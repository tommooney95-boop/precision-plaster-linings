# Resend API key for quote email delivery (get one free at https://resend.com)
RESEND_API_KEY=

# Email addresses for quote submissions
QUOTE_EMAIL_TO=info@precisionplasterlinings.com.au
QUOTE_EMAIL_FROM=quotes@precisionplasterlinings.com.au

# Google Search Console verification token (optional)
GSC_VERIFICATION=

# Admin login password for /admin (required in production)
DASHBOARD_PASSWORD=your-secure-password-here

# Optional separate session signing secret (defaults to DASHBOARD_PASSWORD)
SESSION_SECRET=

# Supabase — stores leads permanently in production.
# If left blank, the app falls back to local file storage (dev only).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Business Profile “Write a review” link (required for review requests)
GOOGLE_REVIEW_URL=

# Twilio SMS — customer review texts + optional owner alerts
# Sign up at https://www.twilio.com (AU numbers supported)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+61xxxxxxxxx

# Optional: owner mobile for SMS when a new enquiry arrives (E.164 or AU format)
OWNER_SMS_TO=0400000000
